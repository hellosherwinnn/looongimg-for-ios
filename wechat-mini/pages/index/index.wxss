/**index.wxss**/
.header {
  padding: 30rpx 40rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.logo-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.icon-box {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(to bottom right, #3b82f6, #4f46e5);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  font-size: 40rpx;
}

.title-area {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
}

.subtitle {
  font-size: 20rpx;
  color: #888;
  font-weight: bold;
  text-transform: uppercase;
}

.main-content {
  padding: 40rpx;
}

.upload-box {
  background-color: #fff;
  border-radius: 40rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.05);
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.upload-desc {
  font-size: 24rpx;
  color: #888;
}

.video-preview {
  margin-bottom: 40rpx;
}

.video-element {
  width: 100%;
  height: 600rpx;
  border-radius: 30rpx;
  margin-bottom: 30rpx;
  background-color: #000;
}

.primary-btn {
  background-color: #1D1D1F;
  color: #fff;
  border-radius: 20rpx;
  font-weight: bold;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.save-btn {
  background-color: #3b82f6;
  margin-top: 30rpx;
}

.result-area {
  margin-top: 40rpx;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
}

.success-text {
  display: block;
  font-size: 28rpx;
  color: #10b981;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.result-image {
  width: 100%;
  border-radius: 20rpx;
}

/* Offscreen visual representation of our canvas */
.offscreen-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1000px;
  height: 10000px;
}
